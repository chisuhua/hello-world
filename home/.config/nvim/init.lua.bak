-- ~/.config/nvim/init.lua
vim.g.mapleader = " "
vim.opt.number = true
vim.opt.relativenumber = true
vim.opt.mouse = 'a'
vim.opt.termguicolors = true
vim.opt.signcolumn = 'yes'
vim.opt.updatetime = 300
vim.opt.expandtab = true
vim.opt.tabstop = 4
vim.opt.shiftwidth = 4

-- 插件管理：lazy.nvim
local lazypath = vim.fn.stdpath("data") .. "/lazy/lazy.nvim"
if not vim.loop.fs_stat(lazypath) then
  vim.fn.system({
    "git", "clone", "--filter=blob:none",
    "https://github.com/folke/lazy.nvim.git",
    "--branch=stable", lazypath
  })
end
vim.opt.rtp:prepend(lazypath)

require("lazy").setup({
  -- Treesitter (语法高亮 + 结构)
  {
    "nvim-treesitter/nvim-treesitter",
    build = ":TSUpdate",
    config = function()
      require("nvim-treesitter.config").setup({
        ensure_installed = { "cpp", "c", "cmake", "gitcommit" },
        highlight = { enable = true },
        indent = { enable = true }
      })
    end
  },

  -- LSP (使用 Neovim ≥ v0.10 新 API)
  {
    "neovim/nvim-lspconfig",
    dependencies = {
      "williamboman/mason.nvim",
      "williamboman/mason-lspconfig.nvim"
    },
    config = function()
      -- 安装 clangd
      require("mason").setup()
      require("mason-lspconfig").setup({ ensure_installed = { "clangd" } })

      -- 配置 clangd
      local clangd_config = {
        cmd = { "clangd", "--background-index", "--clang-tidy" },
        on_attach = function(client, bufnr)
          local opts = { buffer = bufnr, noremap = true, silent = true }
          vim.keymap.set("n", "gd", vim.lsp.buf.definition, opts)
          vim.keymap.set("n", "gr", vim.lsp.buf.references, opts)
          vim.keymap.set("n", "K", vim.lsp.buf.hover, opts)
          vim.keymap.set("n", "<leader>rn", vim.lsp.buf.rename, opts)
          vim.keymap.set("n", "<leader>ca", vim.lsp.buf.code_action, opts)
        end
      }
      vim.lsp.config.clangd = clangd_config

      -- 自动启动 LSP
      vim.api.nvim_create_autocmd("BufEnter", {
        pattern = { "*.c", "*.cpp", "*.h", "*.hpp" },
        callback = function() vim.lsp.start({ name = "clangd" }) end
      })
    end
  },
  {
      "nvim-neotest/nvim-nio", -- 必须先于 dap-ui 加载
  },
  -- Debug (GDB)
  {
    "mfussenegger/nvim-dap",
    dependencies = {
      "rcarriga/nvim-dap-ui",
      "theHamsta/nvim-dap-virtual-text"
    },
    config = function()
      local dap = require("dap")
      local dapui = require("dapui")
      dapui.setup()

      dap.adapters.cppdbg = {
        id = 'cppdbg',
        type = 'executable',
        command = '/usr/bin/gdb'
      }

      dap.configurations.cpp = {{
        name = "Launch",
        type = "cppdbg",
        request = "launch",
        program = function()
          return vim.fn.input('Path to executable: ', vim.fn.getcwd() .. '/', 'file')
        end,
        cwd = '${workspaceFolder}',
        stopOnEntry = false,
        setupCommands = {{ text = "-enable-pretty-printing" }}
      }}

      vim.keymap.set("n", "<F5>", dap.continue, { noremap = true })
      vim.keymap.set("n", "<F10>", dap.step_over, { noremap = true })
      vim.keymap.set("n", "<F11>", dap.step_into, { noremap = true })
      vim.keymap.set("n", "<leader>b", dap.toggle_breakpoint, { noremap = true })
      vim.keymap.set("n", "<leader>du", dapui.open, { noremap = true })
    end
  },

  -- Git signs
  {
    "lewis6991/gitsigns.nvim",
    config = function()
      require("gitsigns").setup({
        on_attach = function(bufnr)
          local gs = package.loaded.gitsigns
          local map = function(l, r)
            vim.keymap.set("n", l, r, { buffer = bufnr, noremap = true })
          end
          map("gb", gs.blame_line)
          map("<leader>hs", gs.stage_hunk)
          map("<leader>hr", gs.reset_hunk)
        end
      })
    end
  },

  -- Git timeline (Neogit)
  {
    "NeogitOrg/neogit",
    dependencies = { "nvim-lua/plenary.nvim" },
    config = function()
      require("neogit").setup({
        graph_style = "unicode",
        kind = "vsplit"
      })
    end
  },

  -- Fuzzy finder
  {
    "nvim-telescope/telescope.nvim",
    dependencies = { "nvim-lua/plenary.nvim" },
    config = function()
      local map = function(k, f) vim.keymap.set("n", k, f, { noremap = true }) end
      map("<leader>ff", require("telescope.builtin").find_files)
      map("<leader>fS", require("telescope.builtin").lsp_workspace_symbols)
      map("<leader>gC", require("telescope.builtin").git_bcommits)
    end
  },

  -- Statusline
  {
    "nvim-lualine/lualine.nvim",
    dependencies = { "nvim-tree/nvim-web-devicons" },
    config = true
  }
}, {
  ui = { border = "rounded" },
  performance = {
    rtp = { disabled_plugins = { "gzip", "matchit", "matchparen", "tarPlugin", "tohtml", "tutor", "zipPlugin" } }
  }
})

-- Kitty 剪贴板集成（仅当 kitty CLI 存在时启用）
if vim.fn.executable("kitty") == 1 then
  local function copy(text)
    local handle = io.popen("kitty @ copy-to-clipboard", "w")
    if handle then handle:write(text); handle:close() end
  end
  local function paste()
    local handle = io.popen("kitty @ paste-from-clipboard", "r")
    if handle then local t = handle:read("*a"); handle:close(); return t end
    return ""
  end
  vim.g.clipboard = {
    name = "kitty",
    copy = { ["+"] = copy, ["*"] = copy },
    paste = { ["+"] = paste, ["*"] = paste },
  }
end
